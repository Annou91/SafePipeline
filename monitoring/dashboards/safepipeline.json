{
  "title": "SafePipeline — App Metrics",
  "uid": "safepipeline-main",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flask_http_request_total[1m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flask_http_request_total{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status}} {{path}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(flask_http_request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95 {{path}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed Login Attempts",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "flask_http_request_total{path=\"/login\", status=\"200\", method=\"POST\"}",
          "legendFormat": "Login OK"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "flask_http_request_total",
          "legendFormat": "Total"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {}
}
