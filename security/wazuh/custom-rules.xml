<!-- SafePipeline — Custom Wazuh detection rules -->
<group name="safepipeline,web,">

  <!-- ----------------------------------------------------------------
       Base rule: match any SafePipeline app log
  ----------------------------------------------------------------- -->
  <rule id="100001" level="0">
    <decoded_as>json</decoded_as>
    <field name="app">safepipeline</field>
    <description>SafePipeline app log</description>
  </rule>

  <!-- ----------------------------------------------------------------
       Brute force: failed login attempt
  ----------------------------------------------------------------- -->
  <rule id="100002" level="5">
    <if_sid>100001</if_sid>
    <field name="event">login_failed</field>
    <description>SafePipeline: failed login attempt for user $(username)</description>
    <group>authentication_failed,</group>
  </rule>

  <rule id="100003" level="10" frequency="5" timeframe="60">
    <if_matched_sid>100002</if_matched_sid>
    <same_field>src_ip</same_field>
    <description>SafePipeline: brute force attack — 5 failed logins in 60s from $(src_ip)</description>
    <group>authentication_failures,brute_force,</group>
  </rule>

  <!-- ----------------------------------------------------------------
       SQL Injection attempt detected in URL or body
  ----------------------------------------------------------------- -->
  <rule id="100004" level="12">
    <if_sid>100001</if_sid>
    <field name="event">sqli_attempt</field>
    <description>SafePipeline: SQL injection attempt from $(src_ip)</description>
    <group>attack,sql_injection,</group>
  </rule>

  <!-- ----------------------------------------------------------------
       XSS attempt detected
  ----------------------------------------------------------------- -->
  <rule id="100005" level="10">
    <if_sid>100001</if_sid>
    <field name="event">xss_attempt</field>
    <description>SafePipeline: XSS attempt from $(src_ip)</description>
    <group>attack,xss,</group>
  </rule>

</group>
